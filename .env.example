# ===========================================
# Telegram Bot sozlamalari
# ===========================================
BOT_TOKEN=7000000000:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=QuizMasterBot
ADMIN_IDS=123456789

# ===========================================
# API & WebApp
# ===========================================
API_HOST=0.0.0.0
API_PORT=8080
# Render.com da avtomatik beradi, o'zingiz qo'yisangiz ham bo'ladi:
# API_BASE_URL=https://your-app-name.onrender.com
# WEBAPP_URL=https://your-app-name.onrender.com

# ===========================================
# Database (SQLite - Render free tier)
# ===========================================
DATABASE_URL=sqlite+aiosqlite:///./data/quiz.db

# ===========================================
# Security
# ===========================================
JWT_SECRET=change-me-to-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ===========================================
# File uploads
# ===========================================
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,doc,docx,xlsx,xls,txt,pptx

# ===========================================
# Limits (Free tier)
# ===========================================
FREE_TESTS_PER_DAY=5
FREE_TESTS_PER_MONTH=20
MAX_QUESTIONS_PER_TEST=50
MAX_FREE_QUESTIONS=10

# ===========================================
# Payments (ixtiyoriy)
# ===========================================
PROVIDER_PAYME=
PROVIDER_CLICK=

# ===========================================
# Premium narxlar (tiyin)
# ===========================================
PREMIUM_MONTHLY_PRICE=49900
PREMIUM_YEARLY_PRICE=499000
PREMIUM_LIFETIME_PRICE=999000
TRIAL_DAYS=3

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
